{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "detb/event-timeline",
  "version": "0.1.0",
  "title": "Event Timeline",
  "category": "widgets",
  "icon": "calendar-alt",
  "description": "Create interactive event timelines with dates, images, and icons.",
  "keywords": ["timeline", "events", "history"],
  "textdomain": "dynamic-event-timeline-block",
  "attributes": {
    "events": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "properties": {
          "id":          { "type": "string" },
          "title":       { "type": "string" },
          "date":        { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "orientation": {
      "type": "string",
      "default": "vertical"
    },
    "darkMode": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "color": {
      "background": true,
      "text": true
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}